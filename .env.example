# Local development only. Do not commit real values in .env.local.

# Google Gemini API key (optional in file, usually inserted via UI/localStorage)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Clerk publishable key
VITE_CLERK_PUBLISHABLE_KEY=YOUR_CLERK_PUBLISHABLE_KEY

# SCORM reporting endpoint embedded in generated packages
VITE_SCORM_REPORTING_ENDPOINT=https://YOUR-SITE.netlify.app/.netlify/functions/scorm-events
